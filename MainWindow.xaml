<Window x:Class="Socket_TCP_Test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Socket_TCP_Test"
        mc:Ignorable="d"
        Title="MainWindow" Height="471" Width="832">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="57*"/>
            <ColumnDefinition Width="151*"/>
        </Grid.ColumnDefinitions>
        <Button x:Name="BtnConnect" Content="連線" Click="BtnConnect_Click" Margin="155,332,521,80" Grid.ColumnSpan="2"/>
        <TextBlock x:Name="TxtStatus" Margin="399,46,30,0" TextWrapping="Wrap" Text="連線狀態" VerticalAlignment="Top" Height="47" RenderTransformOrigin="0.478,0.577" FontSize="20" Background="#FFCBD5A4" Grid.Column="1"/>
        <Label Content="ip" HorizontalAlignment="Left" Margin="59,25,0,0" VerticalAlignment="Top" Height="50" Width="80" FontSize="14" FontFamily="Times New Roman" HorizontalContentAlignment="Center" RenderTransformOrigin="0.508,0.54" VerticalContentAlignment="Center"/>
        <TextBox x:Name="TxtIp" HorizontalAlignment="Left" Margin="39,75,0,0" TextWrapping="Wrap" Text="Type Your IP:" VerticalAlignment="Top" Width="120" TextAlignment="Center" Background="#FF16FFF1" Height="37" GotFocus="IP_Focus"/>

        <TextBlock x:Name="TxtLog" HorizontalAlignment="Left" Margin="399,119,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="175" TextAlignment="Center" FontSize="15" Grid.Column="1" Height="63"><Run Language="zh-tw" Text="LOG"/></TextBlock>

        <UniformGrid Columns="3" Rows="2" Margin="183,53,155,176" Grid.ColumnSpan="2">
            <StackPanel Margin="8">
                <TextBlock Text="J1" FontSize="14" Foreground="Gray"/>
                <TextBlock x:Name="TxtJ1" Text="--" FontSize="24" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Margin="8">
                <TextBlock Text="J2" FontSize="14" Foreground="Gray"/>
                <TextBlock x:Name="TxtJ2" Text="--" FontSize="24" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Margin="8">
                <TextBlock Text="J3" FontSize="14" Foreground="Gray"/>
                <TextBlock x:Name="TxtJ3" Text="--" FontSize="24" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Margin="8">
                <TextBlock Text="J4" FontSize="14" Foreground="Gray"/>
                <TextBlock x:Name="TxtJ4" Text="--" FontSize="24" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Margin="8">
                <TextBlock Text="J5" FontSize="14" Foreground="Gray"/>
                <TextBlock x:Name="TxtJ5" Text="--" FontSize="24" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Margin="8">
                <TextBlock Text="J6" FontSize="14" Foreground="Gray"/>
                <TextBlock x:Name="TxtJ6" Text="--" FontSize="24" FontWeight="Bold"/>
            </StackPanel>
        </UniformGrid>
        <TextBlock x:Name="TxtTime" HorizontalAlignment="Left" Margin="433,151,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="31" Width="141" FontSize="20" TextAlignment="Center"><Run Language="zh-tw" Text="Time"/></TextBlock>
        <Button Grid.Column="1" Content="斷開" HorizontalAlignment="Left" Margin="202,333,0,0" VerticalAlignment="Top" Height="43" Width="100" Click="BtnDisconnect_Click"/>
    </Grid>



</Window>
