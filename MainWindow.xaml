<Window x:Class="Socket_TCP_Test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Socket_TCP_Test"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="471" Width="817" >
    <!-- 設定 DataContext，讓 Binding 找得到 Values1 / Values2 -->


    <Grid >
        <Button x:Name="BtnConnect" Content="連線" Height="32" Width="158" Margin="184,0,0,27" HorizontalAlignment="Left" VerticalAlignment="Bottom" Click="BtnConnect_Click" VerticalContentAlignment="Center" RenderTransformOrigin="0.492,0.56"  />
        <TextBlock x:Name="TxtStatus" Margin="249,18,0,0" TextWrapping="Wrap" Text="連線狀態" VerticalAlignment="Top" Height="47" RenderTransformOrigin="0.478,0.577" FontSize="20" Background="#FFCBD5A4" HorizontalAlignment="Left" Width="113"/>
        <Label Content="ip" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="26" Width="47" FontSize="14" FontFamily="Times New Roman" HorizontalContentAlignment="Center" RenderTransformOrigin="0.508,0.54" VerticalContentAlignment="Center"/>
        <TextBox x:Name="TxtIp" HorizontalAlignment="Left" Margin="53,20,0,0" TextWrapping="Wrap" Text="Type Your IP:" VerticalAlignment="Top" Width="165" TextAlignment="Center" Background="#FF16FFF1" Height="37" GotFocus="IP_Focus"/>

        <TextBlock x:Name="TxtLog" HorizontalAlignment="Right" Margin="0,0,5,132" TextWrapping="Wrap" VerticalAlignment="Bottom" Width="166" TextAlignment="Center" FontSize="15" Height="72"><Run Language="zh-tw" Text="LOG"/></TextBlock>

        <UniformGrid Columns="3" Rows="2" Margin="0,20,11,0" VerticalAlignment="Top" HorizontalAlignment="Right" Width="301" Height="143">
            <StackPanel Margin="8">
                <TextBlock Text="J1" FontSize="14" Foreground="Red" ForceCursor="True"/>
                <CheckBox x:Name="ChkJ1" Content="show" IsChecked="True" Checked="ChkJoint_Changed" Unchecked="ChkJoint_Changed"/>
                <TextBlock x:Name="TxtJ1" Text="--" FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Margin="8">
                <TextBlock Text="J2" FontSize="14" Foreground="Blue"/>
                <CheckBox x:Name="ChkJ2" Content="show" IsChecked="True" Checked="ChkJoint_Changed" Unchecked="ChkJoint_Changed"/>
                <TextBlock x:Name="TxtJ2" Text="--" FontSize="15" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Margin="8">
                <TextBlock Text="J3" FontSize="14" Foreground="Lime"/>
                <CheckBox x:Name="ChkJ3" Content="show" IsChecked="True" Checked="ChkJoint_Changed" Unchecked="ChkJoint_Changed"/>
                <TextBlock x:Name="TxtJ3" Text="--" FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Margin="8">
                <TextBlock Text="J4" FontSize="14" Foreground="Orange"/>
                <CheckBox x:Name="ChkJ4" Content="show" IsChecked="True" Checked="ChkJoint_Changed" Unchecked="ChkJoint_Changed"/>
                <TextBlock x:Name="TxtJ4" Text="--" FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Margin="8">
                <TextBlock Text="J5" FontSize="14" Foreground="Purple"/>
                <CheckBox x:Name="ChkJ5" Content="show" IsChecked="True" Checked="ChkJoint_Changed" Unchecked="ChkJoint_Changed"/>
                <TextBlock x:Name="TxtJ5" Text="--" FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Margin="8">
                <TextBlock Text="J6" FontSize="14" Foreground="Brown"/>
                <CheckBox x:Name="ChkJ6" Content="show" IsChecked="True" Checked="ChkJoint_Changed" Unchecked="ChkJoint_Changed"/>
                <TextBlock x:Name="TxtJ6" Text="--" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </UniformGrid>
        <TextBlock x:Name="TxtTime" HorizontalAlignment="Right" Margin="0,0,171,173" TextWrapping="Wrap" VerticalAlignment="Bottom" Height="31" Width="141" FontSize="20" TextAlignment="Center"><Run Language="zh-tw" Text="Time"/></TextBlock>
        <Button x:Name="dis_connect" Content="斷開" HorizontalAlignment="Right" Margin="0,0,90,32" VerticalAlignment="Bottom" Click="BtnDisconnect_Click" Height="32" Width="162"/>

        <StackPanel Orientation="Horizontal" Margin="10,337,221,69" VerticalAlignment="Bottom" HorizontalAlignment="Left">
            <TextBlock Text="Y Min:" Height="30"  Width="60"/>
            <TextBox x:Name="TxtYMin" Height="30"  Width="60" Text="-10000"/>
            <TextBlock Text="Y Max:" VerticalAlignment="Center" Height="30"  Width="60" Margin="10,0,0,0"/>
            <TextBox x:Name="TxtYMax"  Height="30"  Width="60" Text="10000"/>
            <Button Content="套用軸範圍" Click="BtnApplyAxis_Click"  Height="30"  Width="79" Margin="10,0,0,0"/>
            <TextBlock Text="更新間隔(ms):"  Height="30"  Width="83"/>
            <TextBox x:Name="TxtInterval"  Height="30"  Width="60" Text="50"/>
            <Button Content="套用頻率" Click="BtnApplyInterval_Click"  Height="30"  Width="86"/>
        </StackPanel>
        <oxy:PlotView x:Name="TorquePlotView" Margin="10,82,317,118" Background="#FFF6F0F0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" MinWidth="472" MinHeight="236"/>
        <Button x:Name="Reset_Btn" Content="Reset Plot" HorizontalAlignment="Right" Margin="0,0,123,103" VerticalAlignment="Bottom" Height="29" Width="77" VerticalContentAlignment="Center" Click="BtnResetChart_Click"/>

    </Grid>







</Window>
